generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  tag       String   @default("general")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String @id
  email       String @unique
  displayName String
  password    String
}