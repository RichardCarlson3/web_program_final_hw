<section class="page-intro">
  <p class="eyebrow">Lecture 8.12</p>
  <h1>Journal App Login</h1>
  <p>
    This version adds authentication on top of the 6.11 session flow. The browser still
    has a session object, but now the session can also store the signed-in user identity.
  </p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<%- include("../entries/partials/sessionPanel", { session, outOfBand: false }) %>

<section class="panel auth-panel">
  <div class="panel-header">
    <h2>Sign In</h2>
    <p>
      This demo uses two in-memory users so students can focus on the login and session
      flow before adding a database-backed user model.
    </p>
  </div>

  <form class="journal-form" method="post" action="/login">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" autocomplete="username" required />

    <label for="password">Password</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      required
    />

    <button type="submit">Log in</button>
  </form>

  <div class="demo-users">
    <h3>Demo Users</h3>
    <ul class="credential-list">
      <li><code>alice@journal.test</code> / <code>password123</code></li>
      <li><code>bob@journal.test</code> / <code>password123</code></li>
    </ul>
  </div>
</section>
