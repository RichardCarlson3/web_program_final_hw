<section class="page-intro">
  <p class="eyebrow">Homework 8.13</p>
  <h1>Register</h1>
  <p>Create an account to start using the journal application.</p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<%- include("../entries/partials/sessionPanel", { session, outOfBand: false }) %>

<section class="panel auth-panel">
  <div class="panel-header">
    <h2>Create Account</h2>
    <p>Fill out the form below to register and sign in immediately.</p>
  </div>

  <form class="journal-form" method="post" action="/register">
    <label for="email">Email</label>
    <input id="email" name="email" type="email" required />

    <label for="displayName">Display Name</label>
    <input id="displayName" name="displayName" type="text" required />

    <label for="password">Password</label>
    <input id="password" name="password" type="password" required />

    <label for="confirmPassword">Confirm Password</label>
    <input id="confirmPassword" name="confirmPassword" type="password" required />

    <button type="submit">Register</button>
  </form>

  <p class="demo-users">
    Already have an account?
    <a href="/login">Back to login</a>
  </p>
</section>